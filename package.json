{
  "name": "grok-build-desktop",
  "version": "0.1.0",
  "description": "Desktop client for Grok Build on macOS and Windows — project switcher, sessions, and full slash-command support via ACP",
  "main": "dist-electron/main.js",
  "author": "local",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "start": "electron .",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:dev:raw": "node scripts/electron-dev.mjs",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test:windows": "tsc -p tsconfig.electron.json && node --test electron/env.test.cjs",
    "pack:mac": "npm run build && electron-builder --mac dmg --arm64",
    "pack:win": "npm run build && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.33",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-context-menu": "^2.3.3",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-hover-card": "^1.1.19",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-toggle": "^1.1.14",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@radix-ui/react-visually-hidden": "^1.2.7",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^7.0.30",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "nanoid": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/highlight.js": "^9.12.4",
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "electron": "^35.5.1",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.local.grok-build-desktop",
    "productName": "Grok Build Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/assets/image/icon.png",
      "package.json"
    ],
    "mac": {
      "icon": "electron/assets/image/icon.png",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "electron/assets/image/icon.png",
      "target": [
        "nsis"
      ]
    }
  }
}
